{
  "scripts": {
    "dev:host": "cd host && npm run dev",
    "dev:remote": "cd remote && npm run dev",
    "dev:remote2": "cd remote2 && npm run dev",
    "dev": "concurrently \"npm run dev:host\" \"npm run dev:remote\" \"npm run dev:remote2\""
  },
  "devDependencies": {
    "@happycode-core/prettier": "^1.0.0",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1"
  }
}
